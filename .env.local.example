# ============================================
# Rocatrol AI — Variables de entorno
# ============================================
# IMPORTANTE:
#   1. Copia este archivo a `.env.local` y llena los valores reales.
#   2. NUNCA subas `.env.local` a git (ya está en .gitignore).
#   3. NUNCA pegues las claves reales en chat ni docs públicas.

# --- Supabase (sistema nuevo 2026: sb_publishable_* / sb_secret_*) ---
# Obtener en: https://supabase.com/dashboard → tu proyecto → Settings → API Keys
# Importante: usa el sistema NUEVO. NO uses las legacy JWT (anon / service_role).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxx

# --- Anthropic Claude API ---
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# --- Stripe (futuro, no necesario día 1) ---
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
