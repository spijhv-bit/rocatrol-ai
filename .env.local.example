# ============================================
# Rocatrol AI — Variables de entorno
# ============================================
# IMPORTANTE: Copia este archivo a `.env.local` y llena los valores.
# NUNCA subas `.env.local` a git (ya está en .gitignore).

# --- Supabase ---
# Obtener en: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Anthropic Claude API ---
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

